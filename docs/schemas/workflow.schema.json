{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://brownkit.dev/schemas/workflow.schema.json",
  "title": "BrownKit pipeline state",
  "description": "Phase status tracker. Updated by every command at completion.",
  "type": "object",
  "required": ["schema_version", "pipeline", "phases", "adaptations", "notes"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "1.0" },
    "pipeline":       { "const": "EDCR" },
    "phases": {
      "type": "object",
      "required": ["init", "scan", "discover", "report", "assess", "generate", "finish"],
      "additionalProperties": false,
      "patternProperties": {
        "^(init|scan|discover|report|assess|generate|finish)$": { "$ref": "#/$defs/phase" }
      }
    },
    "adaptations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "db_schema_analysis": { "enum": ["auto", "skip"] },
        "frontend_analysis":  { "enum": ["auto", "skip"] },
        "coverage_source":    { "enum": ["auto", "report", "proxy"] }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "phase": {
      "type": "object",
      "required": ["status", "started_at", "completed_at", "artifacts"],
      "additionalProperties": false,
      "properties": {
        "status":       { "enum": ["pending", "in_progress", "completed", "skipped"] },
        "started_at":   { "type": ["string", "null"] },
        "completed_at": { "type": ["string", "null"] },
        "artifacts":    { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
